**/*mockup*.html
**/*.mock.html
/mocks/

# Superpowers Visual Companion session state
.superpowers/

# Editor / machine-local (not published), including Cursor rules
/.cursor/
/.vscode/
/specs/
# Agent/workspace policy (Cursor + local maintainers). Must stay untracked — never commit, never `git add -f`.
AGENTS.md
# Optional local architecture notes at repo root — not part of the shipped doc surface.
/ARCHITECTURE.md

# Agent runtime artifacts in workspace (detect digest); do not commit
.coldstep-detect.md
.coldstep-agent.stderr.log

# Local deep-debug pass output (scripts/deep-debug.sh)
.coldstep-deep-debug/

# Local-only trees — never staged, never committed (do not `git add` docs/ or knowledge/, never `git add -f`).
/plans/
/skills/
/docs/
/knowledge/
/.worktrees/
# Soft alias junction (mklink /J elon knowledge) — same vault, local-only.
/elon/
# Ignore stray copies under .github only.
/.github/design/
