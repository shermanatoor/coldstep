# Build outputs (repo root; e.g. scripts/build-agent-linux.sh → bin/coldstep)
/bin/
/node_modules/

# Local Windows tooling binaries (not published)
*.exe

# Generated BPF: scripts/build-agent-linux.sh (host bpftool → vmlinux.h) and bpf2go outputs.
bpf/vmlinux.h
internal/bpf/**/*.o
internal/bpf/**/*_bpfel.go
internal/bpf/**/*_bpfeb.go
scripts/__pycache__/

# Local Docker MCP Toolkit reconnect helper (copy from scripts/docker-mcp-reconnect.ps1.example)
scripts/docker-mcp-reconnect.ps1

# Secrets
.env

# Editor / machine-local (not published), including Cursor rules
/.cursor/
/.vscode/
/specs/
AGENTS.md

# Agent runtime artifacts in workspace (detect digest); do not commit
.coldstep-detect.md
.coldstep-agent.stderr.log
scripts/__pycache__/
/docs/

# Local deep-debug pass output (scripts/deep-debug.sh)
.coldstep-deep-debug/

# Agent/design specs (local only; do not publish)
/.github/design/

# Markdown / Obsidian vault — entire tree local only; nothing under knowledge/ is committed (see AGENTS.md).
# Keep knowledge/README.md and knowledge/Index.md in your working tree; do not delete them; do not git add -f.
/knowledge/

# Knowledge vault tooling used to live here; keep ignored so it is never committed by mistake.
/scripts/knowledge_records_backfill.py
